{
    "manifest_version": 2,
    "name": "New Tab",
    "version": "0.1",
    "description": "This extension customizes the new tab page.",
    "chrome_url_overrides": {
      "newtab": "index.html"
    },
    "web_accessible_resources": [
      "images/*",
      "images.json"
    ],
    "permissions": [
      "storage"
    ],
    "icons": {
      "48": "icon.png"
  }
  }
  